# Copie este archivo a .env y complete DATABASE_URL
# Supabase → Database → Connection string → URI (directa, puerto 5432)
# Si su red no soporta IPv6: elija "Session pooler" y use esa URI en su lugar
# DATABASE_URL=postgresql://postgres:SU_PASSWORD@db.SU_PROYECTO.supabase.co:5432/postgres

DATABASE_URL=

PORT=5000
FLASK_DEBUG=1
